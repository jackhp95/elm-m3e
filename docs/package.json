{
  "name": "m3e-builder-docs",
  "type": "module",
  "packageManager": "pnpm@10.30.3",
  "scripts": {
    "build:reference": "node scripts/extract-reference.mjs",
    "build:examples-source": "node scripts/examples-gen/extract-matraic-examples.mjs",
    "build:examples": "node scripts/build-examples-data.mjs",
    "build:examples-config": "node scripts/examples-gen/examples-to-elm.mjs",
    "build:examples-surfaces": "node scripts/examples-gen/gen-record-build.mjs",
    "build:examples-barrel": "node scripts/examples-gen/gen-barrel.mjs",
    "test:examples-gen": "node --test scripts/examples-gen/lib/*.test.mjs",
    "verify:roundtrip": "node scripts/verify-roundtrip.mjs",
    "verify:rule-roundtrip": "node scripts/examples-gen/verify-rule-roundtrip.mjs",
    "test:roundtrip": "node --test scripts/roundtrip/*.test.mjs",
    "check:nav": "node scripts/check-nav.mjs",
    "build:assets": "npm run build:reference && npm run build:examples-config && npm run build:examples-surfaces && npm run build:examples-barrel && npm run build:examples && npm run check:nav",
    "gen": "elm-pages gen && echo 'elm-pages gen: OK (.elm-pages regenerated)'",
    "start": "npm run build:assets && elm-pages dev",
    "build": "npm run build:assets && elm-pages build",
    "build:ci": "npm run build:reference && npm run check:nav && elm-pages build",
    "check": "npm run build:assets && elm-pages build",
    "serve:dist": "node scripts/serve-dist.mjs dist",
    "test:browser": "playwright test"
  },
  "devDependencies": {
    "@playwright/test": "^1.61.1",
    "@tailwindcss/vite": "^4.3.2",
    "elm": "^0.19.1-6",
    "elm-format": "^0.8.8",
    "elm-pages": "^3.5.0",
    "elm-review": "^2.13.5",
    "lamdera": "^0.19.1-1.4.0",
    "tailwindcss": "^4.3.2",
    "vite": "^8.1.4"
  },
  "dependencies": {
    "@m3e/web": "^2.5.14",
    "linkedom": "^0.18.13",
    "tslib": "^2.8.1"
  },
  "pnpm": {
    "overrides": {
      "tslib": "^2.8.1"
    }
  }
}
