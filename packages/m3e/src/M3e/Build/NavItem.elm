{-| Build the `<m3e-nav-item>` element from a `Builder`. -}
build :
    Builder a s msg kind
    -> M3e.Element.Element { navItem : M3e.Value.Supported } msg
build b_ =
    M3e.Element.Internal.fromNode (M3e.Build.Internal.node_ b_)